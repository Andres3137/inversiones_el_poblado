{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "meta": {
    "name": "El Umbral — Inversiones El Poblado",
    "version": "1.0.0",
    "prefix": "ep",
    "description": "Design tokens propietarios. Capas: primitive -> semantic -> component. Los componentes consumen semantic, nunca primitive.",
    "proportionLaw": "90% neutral / 8% copper / 2% ladera-green. Green solo en dato positivo."
  },
  "primitive": {
    "color": {
      "carbon": {
        "950": "#0D0B09", "900": "#14110E", "800": "#1F1B16", "700": "#2C2721",
        "600": "#3D362D", "500": "#574E42", "400": "#8A827A", "300": "#B4ABA0",
        "200": "#D3CABB", "100": "#E4DCD0", "50": "#EDE6DA", "25": "#F6F1E9"
      },
      "copper": {
        "700": "#7A5230", "600": "#94663C", "500": "#B07A48",
        "400": "#C4966A", "300": "#D8B591", "200": "#EAD6C0"
      },
      "ladera": {
        "700": "#1D2A22", "600": "#2E4034", "500": "#3E5647", "300": "#7A9482"
      },
      "signal": {
        "danger": "#8C3B34", "warning": "#A9793B", "info": "#4A5A6A"
      }
    }
  },
  "semantic": {
    "bg": {
      "base": "{primitive.color.carbon.900}",
      "warm": "{primitive.color.carbon.50}",
      "inset": "{primitive.color.carbon.950}",
      "overlay": "rgba(13,11,9,0.72)"
    },
    "surface": {
      "1": "{primitive.color.carbon.800}",
      "2": "{primitive.color.carbon.700}",
      "warm": "{primitive.color.carbon.25}"
    },
    "accent": {
      "default": "{primitive.color.copper.500}",
      "hover": "{primitive.color.copper.400}",
      "press": "{primitive.color.copper.600}"
    },
    "text": {
      "primary": "{primitive.color.carbon.50}",
      "secondary": "{primitive.color.carbon.300}",
      "muted": "{primitive.color.carbon.400}",
      "onWarm": "{primitive.color.carbon.900}"
    },
    "success": {
      "default": "{primitive.color.ladera.600}",
      "fg": "{primitive.color.ladera.300}"
    },
    "border": {
      "default": "{primitive.color.carbon.700}",
      "warm": "{primitive.color.copper.200}",
      "focus": "{primitive.color.copper.400}"
    }
  },
  "opacity": {
    "disabled": 0.38,
    "muted": 0.64,
    "veil": 0.72,
    "hoverTint": 0.08,
    "grain": 0.06
  },
  "typography": {
    "family": {
      "display": "\"Canela\", \"Reckless\", Georgia, serif",
      "serifText": "\"Freight Text\", \"Lyon\", serif",
      "sans": "\"Söhne\", \"Neue Haas Grotesk\", system-ui, sans-serif",
      "mono": "\"Söhne Mono\", \"Diatype Mono\", ui-monospace, monospace"
    },
    "scale": {
      "display-1": { "size": "5.5rem",   "weight": 300, "lineHeight": 1.02, "tracking": "-0.03em", "family": "display" },
      "display-2": { "size": "4rem",     "weight": 300, "lineHeight": 1.05, "tracking": "-0.02em", "family": "display" },
      "h1":        { "size": "3rem",     "weight": 400, "lineHeight": 1.1,  "tracking": "-0.02em", "family": "display" },
      "h2":        { "size": "2.25rem",  "weight": 400, "lineHeight": 1.15, "tracking": "-0.01em", "family": "display" },
      "h3":        { "size": "1.75rem",  "weight": 400, "lineHeight": 1.3,  "tracking": "0",       "family": "serifText" },
      "data-xl":   { "size": "4.5rem",   "weight": 400, "lineHeight": 1.0,  "tracking": "-0.01em", "family": "mono" },
      "body-lg":   { "size": "1.25rem",  "weight": 400, "lineHeight": 1.6,  "tracking": "0",       "family": "serifText" },
      "body":      { "size": "1rem",     "weight": 400, "lineHeight": 1.6,  "tracking": "0",       "family": "sans" },
      "caption":   { "size": "0.8125rem","weight": 500, "lineHeight": 1.4,  "tracking": "0.08em",  "family": "mono", "transform": "uppercase" },
      "micro":     { "size": "0.6875rem","weight": 500, "lineHeight": 1.3,  "tracking": "0.12em",  "family": "mono", "transform": "uppercase" }
    },
    "baseline": "8px"
  },
  "spacing": {
    "0": "0", "1": "4px", "2": "8px", "3": "12px", "4": "16px", "5": "24px",
    "6": "32px", "7": "48px", "8": "64px", "9": "96px", "10": "128px",
    "11": "160px", "12": "200px"
  },
  "grid": {
    "columns": 12,
    "gutter": { "desktop": "24px", "mobile": "16px" },
    "margin": "clamp(20px, 6vw, 120px)",
    "contentMax": "1240px",
    "editorialMax": "720px",
    "bleedMax": "1600px",
    "annotationColumn": 2
  },
  "breakpoints": {
    "xs": "0px", "sm": "480px", "md": "768px", "lg": "1024px", "xl": "1440px"
  },
  "radius": {
    "none": "0", "sm": "2px", "md": "4px", "lg": "8px", "pill": "999px"
  },
  "shadow": {
    "elev-0": "none",
    "elev-1": "0 1px 2px rgba(13,11,9,0.20)",
    "elev-2": "0 4px 16px rgba(13,11,9,0.24)",
    "elev-3": "0 12px 40px rgba(13,11,9,0.30)",
    "elev-warm": "0 8px 32px rgba(122,82,48,0.14)",
    "elev-focus": "0 0 0 1.5px #C4966A"
  },
  "motion": {
    "easing": {
      "ascenso": "cubic-bezier(0.22, 1, 0.36, 1)",
      "umbral": "cubic-bezier(0.83, 0, 0.17, 1)",
      "revelado": "cubic-bezier(0.16, 1, 0.3, 1)",
      "standard": "cubic-bezier(0.4, 0, 0.2, 1)"
    },
    "duration": {
      "instant": "120ms",
      "fast": "240ms",
      "base": "360ms",
      "slow": "560ms",
      "umbral": "760ms"
    },
    "support": {
      "shiftReveal": "24px",
      "parallaxRatio": 0.12,
      "stagger": "60ms",
      "magnetMax": "6px"
    }
  },
  "iconography": {
    "style": "line, contour-derived, open",
    "stroke": { "default": "1.5px", "small": "1.25px" },
    "linecap": "round",
    "linejoin": "round",
    "grid": "24px",
    "keyline": "20px",
    "sizes": ["16", "20", "24", "32"],
    "color": "currentColor",
    "accentDetailMax": 1
  },
  "component": {
    "button": {
      "height": "48px",
      "minTouch": "44px",
      "radius": "{radius.md}",
      "paddingY": "{spacing.3}",
      "paddingX": "{spacing.5}",
      "magnetMax": "{motion.support.magnetMax}"
    },
    "input": {
      "radius": "{radius.sm}",
      "style": "underline",
      "borderDefault": "{semantic.border.default}",
      "borderFocus": "{semantic.accent.default}",
      "paddingY": "{spacing.3}"
    },
    "card": {
      "radius": "{radius.md}",
      "padding": "{spacing.5}",
      "gap": "{spacing.3}",
      "border": "{semantic.border.default}",
      "hoverLift": "-4px"
    },
    "propertyCard": {
      "imageRatio": "4:5",
      "radius": "{radius.md}",
      "hoverZoom": "1.03",
      "elevation": "{shadow.elev-1}"
    },
    "navbar": {
      "heightTop": "80px",
      "heightScrolled": "64px",
      "scrolledBg": "rgba(20,17,14,0.85)",
      "blur": "12px"
    },
    "modal": {
      "radius": "{radius.lg}",
      "surface": "{semantic.surface.1}",
      "overlay": "{semantic.bg.overlay}",
      "elevation": "{shadow.elev-3}",
      "enterEasing": "{motion.easing.umbral}"
    }
  },
  "theme": {
    "note": "Cada umbral es un theme que reasigna semantic sin tocar componentes via data-umbral.",
    "ascender":   { "bg": "{semantic.bg.base}",  "temp": "cold",    "activeVoice": "display" },
    "descubrir":  { "bg": "{semantic.bg.base}",  "temp": "warming", "activeVoice": "sans" },
    "pertenecer": { "bg": "{semantic.bg.warm}",  "temp": "warm",    "activeVoice": "serifText" },
    "invertir":   { "bg": "{semantic.surface.warm}", "temp": "neutral", "activeVoice": "mono" },
    "permanecer": { "bg": "{semantic.bg.inset}", "temp": "warm",    "activeVoice": "serifText" }
  }
}
